<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BabyChloe.Mobile.Views.Growth.GrowthPage"
             Title="Growth">

    <ScrollView Padding="20">
        <VerticalStackLayout Spacing="16">
            <Label Text="Log Measurement" FontSize="24" FontAttributes="Bold" />
            <Label Text="{Binding LastMeasurement}" FontSize="14" TextColor="Gray" />

            <Entry Placeholder="Weight (kg) *" Keyboard="Numeric"
                   Text="{Binding WeightKg}" />
            <Entry Placeholder="Length (cm)" Keyboard="Numeric"
                   Text="{Binding LengthCm}" />
            <Entry Placeholder="Head circumference (cm)" Keyboard="Numeric"
                   Text="{Binding HeadCm}" />
            <Entry Placeholder="Notes (optional)"
                   Text="{Binding Notes}" />

            <Button Text="Save Measurement 📏" Command="{Binding LogMeasurementCommand}"
                    HeightRequest="56" FontSize="18" CornerRadius="12" />

            <Label Text="{Binding StatusMessage}" TextColor="Green" HorizontalOptions="Center" />

            <Button Text="View Growth Chart 📈" Margin="0,20,0,0"
                    HeightRequest="48" FontSize="16" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>