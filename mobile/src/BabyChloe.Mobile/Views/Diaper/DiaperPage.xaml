<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:BabyChloe.Mobile.ViewModels.Diaper"
             x:Class="BabyChloe.Mobile.Views.Diaper.DiaperPage"
             Title="Diaper">

    <Grid RowDefinitions="Auto,*,Auto" Padding="20" RowSpacing="20">
        <!-- Statistics -->
        <Frame Grid.Row="0" Padding="16" CornerRadius="12">
            <VerticalStackLayout Spacing="8">
                <Label Text="{Binding TodayCount, StringFormat='Today: {0} changes'}" FontSize="20" FontAttributes="Bold" />
                <Label Text="{Binding InsightMessage}" FontSize="14" TextColor="Gray" />
                <HorizontalStackLayout Spacing="16">
                    <Label Text="{Binding WetCount, StringFormat='💧 {0} wet'}" />
                    <Label Text="{Binding SoiledCount, StringFormat='💩 {0} soiled'}" />
                </HorizontalStackLayout>
            </VerticalStackLayout>
        </Frame>

        <!-- Quick-log buttons -->
        <VerticalStackLayout Grid.Row="1" Spacing="16" VerticalOptions="Center">
            <Button Text="💧 Wet" Command="{Binding LogWetCommand}"
                    HeightRequest="72" FontSize="22" CornerRadius="12" />
            <Button Text="💩 Soiled" Command="{Binding LogSoiledCommand}"
                    HeightRequest="72" FontSize="22" CornerRadius="12" />
            <Button Text="💧💩 Both" Command="{Binding LogBothCommand}"
                    HeightRequest="72" FontSize="22" CornerRadius="12" />
        </VerticalStackLayout>

        <!-- Status -->
        <Label Grid.Row="2" Text="{Binding StatusMessage}" FontSize="14"
               HorizontalOptions="Center" TextColor="Green" />
    </Grid>
</ContentPage>