<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BabyChloe.Mobile.Views.Dashboard.QuickActionPanel">

    <HorizontalStackLayout Spacing="16" HorizontalOptions="Center">
        <Button Text="🌙 Sleep" WidthRequest="100" HeightRequest="48"
                CornerRadius="24" FontSize="14"
                BackgroundColor="{AppThemeBinding Light=#6366F1, Dark=#818CF8}"
                TextColor="White" />
        <Button Text="🍼 Feed" WidthRequest="100" HeightRequest="48"
                CornerRadius="24" FontSize="14"
                BackgroundColor="{AppThemeBinding Light=#F59E0B, Dark=#FBBF24}"
                TextColor="White" />
        <Button Text="🧷 Diaper" WidthRequest="100" HeightRequest="48"
                CornerRadius="24" FontSize="14"
                BackgroundColor="{AppThemeBinding Light=#10B981, Dark=#34D399}"
                TextColor="White" />
    </HorizontalStackLayout>
</ContentView>